<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing Outer Aura Ring -->
    <path
        android:pathData="M54,23A31,31 0,1,1 53.9,23Z"
        android:strokeWidth="1.5"
        android:strokeColor="#3300E5FF"
        android:fillColor="#00000000" />

    <!-- Vinyl Disc Main Body -->
    <path android:pathData="M54,26A28,28 0,1,0 54,82A28,28 0,1,0 54,26Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="26"
                android:startY="26"
                android:endX="82"
                android:endY="82"
                android:type="linear">
                <item android:offset="0.0" android:color="#00ADB5" />
                <item android:offset="0.5" android:color="#2A2E3D" />
                <item android:offset="1.0" android:color="#BD83FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Concentric Vinyl Grooves -->
    <path
        android:pathData="M54,34A20,20 0,1,1 53.9,34Z"
        android:strokeWidth="0.8"
        android:strokeColor="#22FFFFFF"
        android:fillColor="#00000000" />
    <path
        android:pathData="M54,40A14,14 0,1,1 53.9,40Z"
        android:strokeWidth="0.8"
        android:strokeColor="#22FFFFFF"
        android:fillColor="#00000000" />

    <!-- Center Glowing Disc Core -->
    <path android:pathData="M54,46A8,8 0,1,0 54,62A8,8 0,1,0 54,46Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="46"
                android:startY="46"
                android:endX="62"
                android:endY="62"
                android:type="linear">
                <item android:offset="0.0" android:color="#00E5FF" />
                <item android:offset="1.0" android:color="#FF5722" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Center Spindle Hole -->
    <path
        android:pathData="M54,51A3,3 0,1,1 53.9,51Z"
        android:fillColor="#090A11" />
</vector>
